{
  "name": "Student Event Tracker",
  "dockerComposeFile": ["docker-compose.yml"],
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/Systems_Programming_Test1",
  "shutdownAction": "stopCompose",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "go.toolsManagement.autoUpdate": true
      },
      "extensions": [
        "golang.go",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "postCreateCommand": "go mod download && sleep 5 && migrate -database \"postgresql://postgres:postgres@db:5432/student_event_tracker?sslmode=disable\" -path ./migrations up",
  "forwardPorts": [8080, 5432],
  "portsAttributes": {
    "8080": {
      "label": "Go Server",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    }
  }
}